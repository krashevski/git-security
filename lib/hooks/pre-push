#!/usr/bin/env bash
# =============================================================
# Git pre-push hook — Brandmauer v1.0
# Blocks commands in SAFE/NORMAL mode and logs events
# =============================================================

set -euo pipefail

# ---------------- CONFIG ----------------
PREFIX="/usr/local"
SHARE_DIR="$PREFIX/share/brandmauer"
SHAREDLIB_DIR="$SHARE_DIR/shared-lib"
source "$SHAREDLIB_DIR/logging.sh"

# Основные пути
LIB_DIR="$PREFIX/lib/brandmauer"
GIT_DIR="$LIB_DIR/git"
COMMON="$GIT_DIR/common.sh"

SECURITY_ROOT="$HOME/.git-security"
LOG_DIR="$HOME/.local/share/brandmauer/logs"
LOG_FILE="$LOG_DIR/security.log"

mkdir -p "$SECURITY_ROOT" "$LOG_DIR" "$GIT_DIR"

# Подключаем общие функции
if [[ -f "$COMMON" ]]; then
    source "$COMMON"
else
    warn " common.sh missing — some features may not work" >> "$LOG_FILE"
fi

# ---------------- LOGGING ----------------
log() {
    mkdir -p "$(dirname "$LOG_DIR")"
    echo "[$(date '+%F %T')] $*" >> "$LOG_FILE"
}

# ---------------- VALIDATION ----------------
[[ -f "$COMMON" ]] || { error " common.sh missing"; exit 1; }
source "$COMMON"

# ---------------- DETERMINE COMMAND ----------------
BLOCKED_COMMAND="push"  # pre-push hook всегда для push
REPO=$(basename "$(git rev-parse --show-toplevel 2>/dev/null || echo '')")
MODE=$(get_git_mode)

# ---------------- CHECK FORCE PUSH ----------------
if [[ "$*" == *"--force"* ]]; then
    security " [$REPO] Force push denied in $MODE mode."
    log "Force push attempt blocked in $REPO ($MODE mode)"
    exit 1
fi

# ---------------- ENFORCE POLICY ----------------
if [[ "$MODE" == "SAFE" ]]; then
    security " [$REPO] git $BLOCKED_COMMAND is DISABLED in SAFE mode."
    log "Blocked git $BLOCKED_COMMAND in $REPO (SAFE)"
    exit 1
elif [[ "$MODE" == "NORMAL" ]]; then
    # В NORMAL запрещаем только push
    security " [$REPO] git $BLOCKED_COMMAND is DISABLED in NORMAL mode."
    log "Blocked git $BLOCKED_COMMAND in $REPO (NORMAL)"
    exit 1
fi

# ---------------- ALLOW ----------------
log "git $BLOCKED_COMMAND allowed in $REPO ($MODE mode)"
exit 0