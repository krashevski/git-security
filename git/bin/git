#!/usr/bin/env bash
# ===================================================
# git - wrapper для тестирования git pull и git fetch
# ---------------------------------------------------
# директория для срипта : "$HOME"/bin

set -euo pipefail

REAL_GIT="/usr/bin/git"

CMD="${1:-}"
shift || true

# ====== ПОЛИТИКА БЕЗОПАСНОСТИ ======

case "$CMD" in
    pull|merge)
        echo "[SECURITY] git $CMD is DISABLED"
        exit 1
        ;;
    fetch)
        echo "[SECURITY] git fetch is DISABLED"
        exit 1
        ;;
    push)
        echo "[SECURITY] git push is DISABLED"
        exit 1
        ;;
esac

# ====== РАЗРЕШЁННЫЕ КОМАНДЫ ======
exec "$REAL_GIT" "$CMD" "$@"

