#!/usr/bin/env bash
set -euo pipefail

info()  { echo "[INFO] $*"; }
warn()  { echo "[WARN] $*"; }
error() { echo "[ERROR] $*" >&2; }

LIB_DIR="/usr/local/lib/brandmauer"
source "$LIB_DIR/core/init.sh"

source "$LIB_DIR/git/common.sh"

info "Launching Git protection module..."

# Здесь ты можешь подключить свой git-brandmauer
# Например:
exec "$LIB_DIR/ui/menu.sh"

echo "Git module ready."