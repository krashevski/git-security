#!/usr/bin/env bash
# bin/git - обёртка, первичный UX-щит
# ✔ Блокирует:
#    pull
#    push
#    fetch
#    merge
# при любом режиме, кроме OPEN
# ✔ Работает до запуска настоящего git
# ✔ Защищает от ошибок, IDE, алиасов

set -euo pipefail

REAL_GIT="/usr/bin/git"
CMD="${1:-}"
shift || true

# Файл состояния
MODE_FILE="$HOME/.git-security/state/mode"
MODE="$(cat "$MODE_FILE" 2>/dev/null || echo "NORMAL")"

# ====== ПОЛИТИКА БЕЗОПАСНОСТИ ======
case "$CMD" in
    pull|push|fetch|merge)
        if [[ "$MODE" != "OPEN" ]]; then
            echo "[SECURITY] git $CMD is DISABLED in mode $MODE"
            exit 1
        fi
        ;;
esac

# ====== РАЗРЕШЁННЫЕ КОМАНДЫ ======
exec "$REAL_GIT" "$CMD" "$@"
