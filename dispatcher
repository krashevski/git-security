#!/usr/bin/env bash
set -euo pipefail

BASE_DIR="$(dirname "$(realpath "$0")")"

case "${1:-}" in
    git)
        exec "$BASE_DIR/brandmauer-git" "${@:2}"
        ;;
    net)
        exec "$BASE_DIR/brandmauer-net" "${@:2}"
        ;;
    status)
        echo "Brandmauer status:"
        ;;
    *)
        echo "Usage: brandmauer {git|net|status}"
        exit 1
        ;;
esac